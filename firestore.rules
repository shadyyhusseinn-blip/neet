rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Galleries collection
    match /galleries/{galleryId} {
      allow read: if true;
      allow write: if isEditorOrAdmin();
      match /sections/{sectionId} {
        allow read: if true;
        allow write: if isEditorOrAdmin();
        match /photos/{photoId} {
          allow read: if true;
          allow write: if isEditorOrAdmin();
        }
      }
    }

    // Client Deliveries collection
    match /clientDeliveries/{deliveryId} {
      allow read: if true;
      allow write: if isEditorOrAdmin();
    }
    
    // Keep existing rules for other collections
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    match /bookings/{bookingId} {
      allow read: if isAuthenticated();
      allow create, update: if isEditorOrAdmin();
      allow delete: if isAdmin();
    }
    
    match /packages/{packageId} {
      allow read: if isAuthenticated();
      allow create, update: if isEditorOrAdmin();
      allow delete: if isAdmin();
    }
    
    match /expenses/{expenseId} {
      allow read: if isEditorOrAdmin();
      allow create, update: if isEditorOrAdmin();
      allow delete: if isAdmin();
    }
    
    match /revenues/{revenueId} {
      allow read: if isEditorOrAdmin();
      allow create, update: if isEditorOrAdmin();
      allow delete: if isAdmin();
    }
    
    match /customers/{customerId} {
      allow read: if isAuthenticated();
      allow create, update: if isEditorOrAdmin();
      allow delete: if isAdmin();
    }
    
    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Page content collection for CMS
    match /page_content/{pageId} {
      allow read: if true;
      allow write: if isEditorOrAdmin();
    }
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isEditorOrAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['editor', 'admin'];
    }
  }
}
